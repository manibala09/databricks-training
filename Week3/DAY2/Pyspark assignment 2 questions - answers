# =========================
# SELECT
# =========================

# Select only emp_name and salary
df.select("emp_name", "salary").display()

# Select emp_id, emp_name, and department
df.select("emp_id", "emp_name", "department").display()

# Select city, designation, and salary
df.select("city", "designation", "salary").display()

# Select all employees from only IT department with selected columns
df.filter(col("department") == "IT") \
  .select("emp_id", "emp_name", "department").display()

# Select emp_name, joining_date, and salary
df.select("emp_name", "joining_date", "salary").display()

# Select first 5 columns from dataframe
df.select(df.columns[:5]).display()

# Select employees whose salary column only
df.select("salary").display()

# Select emp_name and city for employees from Hyderabad
df.filter(col("city") == "Hyderabad") \
  .select("emp_name", "city").display()

# Select designation and department
df.select("designation", "department").display()

# Select all columns except joining_date
df.drop("joining_date").display()


# =========================
# ALIAS
# =========================

# Display emp_name as employee_name
df.select(col("emp_name").alias("employee_name")).display()

# Display salary as monthly_salary
df.select(col("salary").alias("monthly_salary")).display()

# Display department as dept
df.select(col("department").alias("dept")).display()

# Display joining_date as doj
df.select(col("joining_date").alias("doj")).display()

# Select emp_name as name and city as location
df.select(
    col("emp_name").alias("name"),
    col("city").alias("location")
).display()

# Display designation as job_role
df.select(col("designation").alias("job_role")).display()

# Display age as employee_age
df.select(col("age").alias("employee_age")).display()

# Display salary as emp_salary and department as emp_dept
df.select(
    col("salary").alias("emp_salary"),
    col("department").alias("emp_dept")
).display()

# Display city as work_location
df.select(col("city").alias("work_location")).display()


# =========================
# FILTER / WHERE
# =========================

# Filter employees whose salary is greater than 70000
df.filter(col("salary") > 70000).display()

# Filter employees from Hyderabad
df.filter(col("city") == "Hyderabad").display()

# Filter employees whose age is less than 25
df.filter(col("age") < 25).display()

# Filter employees from IT department
df.filter(col("department") == "IT").display()

# Filter employees whose designation is Developer
df.filter(col("designation") == "Developer").display()

# Filter employees whose salary is between 50000 and 80000
df.filter(col("salary").between(50000, 80000)).display()

# Filter employees whose city is Bangalore
df.filter(col("city") == "Bangalore").display()

# Filter employees who joined after 2022-01-01
df.filter(col("joining_date") > "2022-01-01").display()

# Filter employees whose age is greater than 30
df.filter(col("age") > 30).display()

# Filter employees whose salary is less than 50000
df.filter(col("salary") < 50000).display()

# Filter employees from Chennai and salary greater than 60000
df.filter((col("city") == "Chennai") & (col("salary") > 60000)).display()

# Filter employees from Mumbai or Pune
df.filter((col("city") == "Mumbai") | (col("city") == "Pune")).display()

# Filter employees whose name starts with 'S'
df.filter(col("emp_name").startswith("S")).display()

# Filter employees whose name ends with 'a'
df.filter(col("emp_name").endswith("a")).display()

# Filter employees whose department is HR
df.filter(col("department") == "HR").display()

# Filter employees whose designation contains 'Engineer'
df.filter(col("designation").contains("Engineer")).display()

# Filter employees whose city is not Hyderabad
df.filter(col("city") != "Hyderabad").display()

# Filter employees aged between 25 and 30
df.filter(col("age").between(25, 30)).display()

# Filter employees with salary greater than 90000
df.filter(col("salary") > 90000).display()

# Filter employees from Support department
df.filter(col("department") == "Support").display()


# =========================
# WITHCOLUMNRENAMED
# =========================

# Rename emp_name to employee_name
df.withColumnRenamed("emp_name", "employee_name").display()

# Rename department to dept
df.withColumnRenamed("department", "dept").display()

# Rename joining_date to doj
df.withColumnRenamed("joining_date", "doj").display()

# Rename salary to monthly_salary
df.withColumnRenamed("salary", "monthly_salary").display()

# Rename designation to job_role
df.withColumnRenamed("designation", "job_role").display()

# Rename city to work_location
df.withColumnRenamed("city", "work_location").display()

# Rename age to employee_age
df.withColumnRenamed("age", "employee_age").display()

# Rename emp_id to employee_id
df.withColumnRenamed("emp_id", "employee_id").display()

# Rename department to business_unit
df.withColumnRenamed("department", "business_unit").display()


# =========================
# WITHCOLUMN
# =========================

# Create bonus column as 10% of salary
df.withColumn("bonus", col("salary") * 0.10).display()

# Create annual_salary column
df.withColumn("annual_salary", col("salary") * 12).display()

# Create tax column as 5% of salary
df.withColumn("tax", col("salary") * 0.05).display()

# Create updated_salary by adding 5000
df.withColumn("updated_salary", col("salary") + 5000).display()

# Create salary_category column
df.withColumn(
    "salary_category",
    when(col("salary") > 80000, "High")
    .when(col("salary") > 50000, "Medium")
    .otherwise("Low")
).display()

# Create age_group column
df.withColumn(
    "age_group",
    when(col("age") < 25, "Young")
    .otherwise("Adult")
).display()

# Create location column by combining city and department
df.withColumn(
    "location",
    concat(col("city"), lit("-"), col("department"))
).display()

# Create increment_salary column with 15% hike
df.withColumn(
    "increment_salary",
    col("salary") * 1.15
).display()

# Create name_length column using employee name
df.withColumn(
    "name_length",
    length(col("emp_name"))
).display()

# Create is_high_salary column using condition
df.withColumn(
    "is_high_salary",
    when(col("salary") > 70000, True).otherwise(False)
).display()

# Create joining_year column from joining_date
df.withColumn(
    "joining_year",
    year(to_date(col("joining_date")))
).display()

# Create salary_after_tax column
df.withColumn(
    "salary_after_tax",
    col("salary") - (col("salary") * 0.05)
).display()

# Create department_code column
df.withColumn(
    "department_code",
    substring(col("department"), 1, 2)
).display()

# Create double_salary column
df.withColumn(
    "double_salary",
    col("salary") * 2
).display()


